# =====================================================
# ES Chain - Environment Configuration
# =====================================================

# === Elasticsearch 配置 ===
ES_HOST=es.ai.k8s
ES_PORT=80
ES_SCHEME=http

# === LLM API 配置 ===

# LLM 提供商
LLM_PROVIDER=openai
# API Key
LLM_API_KEY=
# 模型名称
LLM_MODEL=deepseek-v3.2
# API 基础 URL
LLM_BASE_URL=https://your-llm-endpoint/v1
# 请求超时时间
LLM_TIMEOUT=60000