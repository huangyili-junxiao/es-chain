{ "order_id": "ORD-2026-006", "user_id": "USER-1005", "status": "completed", "category": "electronics", "region": "Shenzhen", "amount": 3499.00, "quantity": 1, "product_name": "iPad Air", "created_at": "2026-04-03T16:00:00Z", "paid_at": "2026-04-03T16:05:00Z" }
