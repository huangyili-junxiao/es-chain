      "name": "【核心】自然语言查询 - 订单统计",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"北京地区的已完成订单\",\n  \"request_id\": \"test-orders-001\",\n  \"options\": {\n    \"timeoutMs\": 10000,\n    \"maxResults\": 10\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8004/query",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8004",
          "path": ["query"]
        },
        "description": "预期命中: region=Beijing + status=completed = 3条"
