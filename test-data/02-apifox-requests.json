    {
      "name": "自然语言查询 - 复杂聚合",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"每个服务的错误数量统计\",\n  \"request_id\": \"test-agg-001\",\n  \"options\": {\n    \"timeoutMs\": 10000,\n    \"maxResults\": 0\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8004/query",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8004",
          "path": ["query"]
        },
        "description": "预期返回聚合结果，展示各服务的错误数量分布"
      },
      "response": []
    },
    {
      "name": "直接执行 DSL（调试用）",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"index\": \"factory_sensors\",\n  \"dsl\": {\n    \"query\": {\n      \"bool\": {\n        \"must\": [\n          { \"term\": { \"zone\": \"Zone_A\" } },\n          { \"term\": { \"status\": \"Critical\" } },\n          { \"term\": { \"alert_type\": \"Overheat\" } }\n        ]\n      }\n    },\n    \"size\": 10\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8004/dsl",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8004",
          "path": ["dsl"]
        }
      },
      "response": []
    },
    {
      "name": "DSL 验证接口",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"index\": \"factory_sensors\",\n  \"dsl\": {\n    \"query\": {\n      \"term\": { \"zone\": \"Zone_A\" }\n    },\n    \"size\": 10\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8004/validate",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8004",
          "path": ["validate"]
