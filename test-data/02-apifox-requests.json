    {
      "name": "【核心】自然语言查询 - 工厂传感器",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"A区的高温报警\",\n  \"request_id\": \"test-factory-001\",\n  \"options\": {\n    \"timeoutMs\": 10000,\n    \"maxResults\": 10\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8004/query",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8004",
          "path": ["query"]
        },
        "description": "预期命中: Zone_A + Critical + Overheat = 2条"
      },
      "response": []
    },
    {
      "name": "【核心】自然语言查询 - 错误日志",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"最近有什么错误日志\",\n  \"request_id\": \"test-logs-001\",\n  \"options\": {\n    \"timeoutMs\": 10000,\n    \"maxResults\": 10\n  }\n}"
        },
        "url": {
          "raw": "http://localhost:8004/query",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8004",
          "path": ["query"]
        },
        "description": "预期命中: level=ERROR = 5条"
      },
      "response": []
    },
